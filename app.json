{
  "expo": {
    "name": "More Hub",
    "slug": "more-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "more-hub",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eduar297.more-hub",
      "infoPlist": {
        "NSBonjourServices": [
          "_morehub._tcp.",
          "_http._tcp.",
          "_printer._tcp.",
          "_pdl-datastream._tcp.",
          "_ipp._tcp."
        ],
        "NSLocalNetworkUsageDescription": "Esta app usa la red local para descubrir impresoras y otros dispositivos.",
        "NSLocationWhenInUseUsageDescription": "Usamos tu ubicación para guardar las coordenadas de tu tienda en el mapa.",
        "NSCameraUsageDescription": "Usamos la cámara para escanear códigos de barras y tomar fotos de productos.",
        "NSPhotoLibraryUsageDescription": "Accedemos a tu galería para seleccionar fotos de productos y tiendas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.eduar297.el_more_hub",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-location",
        {
          "isIosBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Usamos la cámara para escanear códigos de barras y tomar fotos de productos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Accedemos a tu galería para seleccionar fotos de productos y tiendas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "da216c1e-7258-42c7-90ca-95ce7439a157"
      }
    }
  }
}
