    "prebuild:ios:clean": "npx expo prebuild --platform ios --clean",
    "prebuild:clean": "npx expo prebuild --clean",
    "web": "expo start --web",
    "lint": "expo lint",
    "relay": "bash scripts/lan-relay.sh"
  },
